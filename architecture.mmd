flowchart TB

%% =========================
%% USER INTERFACE LAYER
%% =========================
subgraph UI["User Interface"]
    User[User]
    Menu[Console Menu]
end

User --> Menu

%% =========================
%% APPLICATION LAYER
%% =========================
subgraph APP["Application Layer"]
    PDFHandler[PDF Handler]
    VideoHandler[Video Handler]
    QAHandler[Q&A Handler]
    Agent[Agent Controller]
end

Menu --> PDFHandler
Menu --> VideoHandler
Menu --> QAHandler
Menu --> Agent

%% =========================
%% PROCESSING LAYER
%% =========================
subgraph PROCESSING["Processing Layer"]
    PDFText[Extract PDF Text]
    Whisper[Whisper Transcription]
    Chunker[Chunking Service]
    Embedder[Embedding Service]
end

PDFHandler --> PDFText --> Chunker
VideoHandler --> Whisper --> Chunker
Chunker --> Embedder

%% =========================
%% DATA LAYER
%% =========================
subgraph DATA["Data Layer"]
    VectorStore[Vector Store Service]
    ChromaDB[(ChromaDB)]
end

Embedder --> VectorStore --> ChromaDB

%% =========================
%% RETRIEVAL (RAG)
%% =========================
subgraph RAG["RAG Pipeline"]
    Query[Query Service]
    RetrievedChunks[Retrieved Chunks]
end

QAHandler --> Query
Query --> ChromaDB
ChromaDB --> RetrievedChunks

%% =========================
%% AGENTIC LAYER
%% =========================
subgraph AGENT["Agentic Layer"]
    Decision[Decide Action (LLM)]
    ToolCall[Tool: Vector Search]
    GenerateAnswer[Generate Answer (LLM)]
    Reflection[Self Reflection (LLM)]
end

Agent --> Decision
Decision -->|search| ToolCall
Decision -->|answer| GenerateAnswer

ToolCall --> Query
RetrievedChunks --> GenerateAnswer

GenerateAnswer --> Reflection

%% =========================
%% LLM SERVICE
%% =========================
subgraph LLM_LAYER["LLM Service"]
    OpenAI[OpenAI API]
end

Decision --> OpenAI
GenerateAnswer --> OpenAI
Reflection --> OpenAI

%% =========================
%% OUTPUT
%% =========================
Reflection --> Output[Final Answer]
Output --> User
